<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.yebur.controller.EmpleadosListController"
            styleClass="modal-card,list-modal-large"
            fx:id="root"
            stylesheets="@shiftCloseReport.css @listados.css">

    <top>
        <HBox styleClass="modal-header" alignment="CENTER_LEFT" spacing="10">
            <Label text="EMPLEADOS" styleClass="modal-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="&#x2715;" styleClass="modal-close" onAction="#onClose"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="0">
            <!-- Filter row -->
            <HBox styleClass="list-filter-row" spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" styleClass="list-filter-field" promptText="Buscar..." prefWidth="220"/>
                <Button text="Limpiar" onAction="#onClear" styleClass="modal-close"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="empleadosTable" styleClass="list-table" VBox.vgrow="ALWAYS"
                       onMouseClicked="#onRowClicked">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="nameCol" text="Nombre" prefWidth="200"/>
                    <TableColumn fx:id="emailCol" text="Email" prefWidth="200"/>
                    <TableColumn fx:id="rolCol" text="Rol" prefWidth="120"/>
                    <TableColumn fx:id="statusCol" text="Estado" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Sin empleados" styleClass="grid-name"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>
