<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml"
             fx:controller="com.yebur.controller.LoginController"
             prefWidth="1024"
             prefHeight="768"
             styleClass="login-root"
             stylesheets="@login.css">

     <VBox alignment="CENTER" spacing="0" styleClass="login-card" maxWidth="400" maxHeight="560">
          <padding>
               <Insets top="48" right="48" bottom="48" left="48"/>
          </padding>

          <VBox alignment="CENTER" spacing="12">
               <ImageView fx:id="logoView" fitWidth="52" fitHeight="52" preserveRatio="true" smooth="true"/>
               <VBox alignment="CENTER" spacing="4">
                    <Text text="Orderly" styleClass="login-title"/>
                    <Text text="Punto de venta" styleClass="login-subtitle"/>
               </VBox>
          </VBox>

          <Region prefHeight="32"/>

          <VBox spacing="6">
               <Label text="Correo electrónico / usuario" styleClass="login-field-label"/>
               <TextField fx:id="emailField"
                            promptText="correo o nombre de usuario"
                            styleClass="login-input"
                            maxWidth="Infinity"/>
          </VBox>

          <Region prefHeight="16"/>

          <VBox spacing="6">
               <Label text="Contraseña" styleClass="login-field-label"/>
               <PasswordField fx:id="passwordField"
                                 styleClass="login-input"
                                 maxWidth="Infinity"/>
          </VBox>

          <Region prefHeight="8"/>

          <Label fx:id="errorLabel"
                  text=""
                  wrapText="true"
                  maxWidth="304"
                  styleClass="login-error"/>

          <Region prefHeight="20"/>

          <Button fx:id="loginButton"
                    text="Iniciar sesión"
                    onAction="#onLogin"
                    maxWidth="Infinity"
                    styleClass="login-button"/>
     </VBox>

</StackPane>
