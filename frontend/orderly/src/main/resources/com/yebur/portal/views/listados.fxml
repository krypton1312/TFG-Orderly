<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.yebur.controller.ListadosController"
      alignment="TOP_CENTER"
      spacing="0"
      styleClass="content-area,list-content-area"
      fx:id="root"
      stylesheets="@listados.css">

    <TilePane styleClass="list-tile-pane"
              prefColumns="4"
              hgap="24" vgap="24"
              alignment="CENTER">

        <!-- Turnos -->
        <VBox styleClass="list-card" alignment="CENTER" spacing="12"
              onMouseClicked="#onTurnosCard">
            <StackPane alignment="CENTER" scaleX="1.4" scaleY="1.4" pickOnBounds="false">
                <SVGPath styleClass="list-card-icon"
                    content="M8 2v4 M16 2v4 M3 10h18 M3 6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            </StackPane>
            <Label text="Turnos" styleClass="list-card-text"/>
        </VBox>

        <!-- Pedidos -->
        <VBox styleClass="list-card" alignment="CENTER" spacing="12"
              onMouseClicked="#onPedidosCard">
            <StackPane alignment="CENTER" scaleX="1.4" scaleY="1.4" pickOnBounds="false">
                <SVGPath styleClass="list-card-icon"
                    content="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2 M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2 M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2 M12 12h.01 M12 16h.01"/>
            </StackPane>
            <Label text="Pedidos" styleClass="list-card-text"/>
        </VBox>

        <!-- Clientes -->
        <VBox styleClass="list-card" alignment="CENTER" spacing="12"
              onMouseClicked="#onClientesCard">
            <StackPane alignment="CENTER" scaleX="1.4" scaleY="1.4" pickOnBounds="false">
                <SVGPath styleClass="list-card-icon"
                    content="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8 M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75"/>
            </StackPane>
            <Label text="Clientes" styleClass="list-card-text"/>
        </VBox>

        <!-- Productos -->
        <VBox styleClass="list-card" alignment="CENTER" spacing="12"
              onMouseClicked="#onProductosCard">
            <StackPane alignment="CENTER" scaleX="1.4" scaleY="1.4" pickOnBounds="false">
                <SVGPath styleClass="list-card-icon"
                    content="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z M12 22V12 M3.29 7L12 12L20.71 7 M7.5 4.27l9 5.15"/>
            </StackPane>
            <Label text="Productos" styleClass="list-card-text"/>
        </VBox>

        <!-- Mesas -->
        <VBox styleClass="list-card" alignment="CENTER" spacing="12"
              onMouseClicked="#onMesasCard">
            <StackPane alignment="CENTER" scaleX="1.4" scaleY="1.4" pickOnBounds="false">
                <SVGPath styleClass="list-card-icon"
                    content="M3 3h18v4H3z M3 10h18v4H3z M3 17h18v4H3z"/>
            </StackPane>
            <Label text="Mesas" styleClass="list-card-text"/>
        </VBox>

        <!-- Categorías -->
        <VBox styleClass="list-card" alignment="CENTER" spacing="12"
              onMouseClicked="#onCategoriasCard">
            <StackPane alignment="CENTER" scaleX="1.4" scaleY="1.4" pickOnBounds="false">
                <SVGPath styleClass="list-card-icon"
                    content="M13.172 2a2 2 0 0 1 1.414.586l6.71 6.71a2.4 2.4 0 0 1 0 3.408l-4.592 4.592a2.4 2.4 0 0 1-3.408 0l-6.71-6.71A2 2 0 0 1 6 9.172V3a1 1 0 0 1 1-1z M2 7v6.172a2 2 0 0 0 .586 1.414l6.71 6.71a2.4 2.4 0 0 0 3.191.193"/>
            </StackPane>
            <Label text="Categorias" styleClass="list-card-text"/>
        </VBox>

        <!-- Empleados -->
        <VBox styleClass="list-card" alignment="CENTER" spacing="12"
              onMouseClicked="#onEmpleadosCard">
            <StackPane alignment="CENTER" scaleX="1.4" scaleY="1.4" pickOnBounds="false">
                <SVGPath styleClass="list-card-icon"
                    content="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8 M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75"/>
            </StackPane>
            <Label text="Empleados" styleClass="list-card-text"/>
        </VBox>

        <!-- Pagos -->
        <VBox styleClass="list-card" alignment="CENTER" spacing="12"
              onMouseClicked="#onPagosCard">
            <StackPane alignment="CENTER" scaleX="1.4" scaleY="1.4" pickOnBounds="false">
                <SVGPath styleClass="list-card-icon"
                    content="M2 10h20 M5 5h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2z"/>
            </StackPane>
            <Label text="Pagos" styleClass="list-card-text"/>
        </VBox>

    </TilePane>
</VBox>
