<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.yebur.controller.PedidosListController"
            styleClass="modal-card,list-modal-large"
            fx:id="root"
            stylesheets="@shiftCloseReport.css @listados.css">

    <top>
        <HBox styleClass="modal-header" alignment="CENTER_LEFT" spacing="10">
            <Label text="PEDIDOS" styleClass="modal-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="&#x2715;" styleClass="modal-close" onAction="#onClose"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="0">
            <!-- Filter row -->
            <HBox styleClass="list-filter-row" spacing="10" alignment="CENTER_LEFT">
                <Label text="DESDE" styleClass="list-filter-label"/>
                <DatePicker fx:id="fromDatePicker" promptText="dd/MM/yyyy" prefWidth="130"/>
                <Label text="HASTA" styleClass="list-filter-label"/>
                <DatePicker fx:id="toDatePicker" promptText="dd/MM/yyyy" prefWidth="130"/>
                <Label text="METODO" styleClass="list-filter-label"/>
                <ComboBox fx:id="metodoPicker" styleClass="list-filter-combo" prefWidth="110"/>
                <Label text="EMPLEADO" styleClass="list-filter-label"/>
                <ComboBox fx:id="empleadoPicker" styleClass="list-filter-combo" prefWidth="140"/>
                <TextField fx:id="searchField" styleClass="list-filter-field" promptText="Buscar..." prefWidth="120"/>
                <Button text="Filtrar" onAction="#onFilter" styleClass="modal-close"/>
                <Button text="Limpiar" onAction="#onClear" styleClass="modal-close"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="pedidosTable" styleClass="list-table" VBox.vgrow="ALWAYS"
                       onMouseClicked="#onRowClicked">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="dateCol" text="Fecha" prefWidth="140"/>
                    <TableColumn fx:id="mesaCol" text="Mesa" prefWidth="60"/>
                    <TableColumn fx:id="estadoCol" text="Estado" prefWidth="90"/>
                    <TableColumn fx:id="totalCol" text="Total" prefWidth="90"/>
                    <TableColumn fx:id="metodoPagoCol" text="M&#xe9;todo" prefWidth="100"/>
                    <TableColumn fx:id="empleadoCol" text="Empleado" prefWidth="160"/>
                </columns>
                <placeholder>
                    <Label text="Sin pedidos" styleClass="grid-name"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>
